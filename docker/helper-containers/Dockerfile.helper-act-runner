# IssuePit act runner image: helper-base + Docker Engine (DinD) + ffmpeg + jq + Go
#
# This is the INNER runner image used by act for workflow job containers
# (the -P ubuntu-latest=<image> mapping). Select this in the IssuePit CI/CD
# settings as the "Runner Image" for workflows that require Playwright tests,
# media processing, or typical CI/CD tooling.
#
# Bases on issuepit-helper-base, which already provides:
#   - Google Chrome / Chromium   — via mcr.microsoft.com/playwright/dotnet base
#   - .NET SDK                   — for dotnet-based workflow steps
#   - Node.js + npm              — for JS-based workflow steps
#   - git, curl, gnupg           — standard VCS and download tooling
#   - s5cmd                      — S3-compatible artifact upload
#
# Additionally installs:
#   - Docker Engine (docker-ce, docker-ce-cli, containerd.io) — enables DinD
#   - ffmpeg     — audio/video processing (required by media workflow steps)
#   - jq         — JSON processor (commonly used in CI scripts)
#   - Go         — required for workflow steps that clone and build Go projects
#                  (e.g. issuepit/act) during E2E CI runs
#
# Build args (override at build time):
#   GO_VERSION  — Go major.minor version tag used for the golang provider image (default: 1.24)
#   BASE_IMAGE  — fully-qualified helper-base image reference

# Global ARGs — must be declared before the first FROM so they are available
# to all FROM instructions in this multi-stage build (Docker scoping rule).
ARG GO_VERSION=1.24
ARG BASE_IMAGE=ghcr.io/issuepit/issuepit-helper-base:latest

# Stage 1: provide the Go toolchain. We use the official golang image as a
# source-only stage so we can COPY /usr/local/go into the final image without
# installing Go via apt (which ships older versions).
FROM golang:${GO_VERSION} AS go-provider

FROM ${BASE_IMAGE}

# Re-declare after FROM so the value is accessible inside this build stage.
ARG GO_VERSION=1.24

# Install Docker Engine (dockerd + CLI + containerd) so that workflow steps can
# use Docker commands inside this container (DinD). The outer helper-act container
# starts dockerd; this image just needs the full Docker stack present so that
# workflows using `docker build`, `docker run`, or service containers work correctly.
# curl and gnupg are already present in the base image.
RUN install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc && \
    chmod a+r /etc/apt/keyrings/docker.asc && \
    . /etc/os-release && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu ${VERSION_CODENAME} stable" \
        > /etc/apt/sources.list.d/docker.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends docker-ce docker-ce-cli containerd.io ffmpeg jq && \
    rm -rf /var/lib/apt/lists/*

# Copy Go toolchain from the go-provider stage so workflow steps that clone and build
# Go projects (e.g. the issuepit/act fork used in E2E tests) can compile without
# requiring a separate Go installation inside the container.
COPY --from=go-provider /usr/local/go /usr/local/go
ENV PATH="/usr/local/go/bin:${PATH}"
RUN go version

# Reset the entrypoint from helper-base: this image is used as an act inner runner
# (workflow job container), not as an IssuePit agent container. The agent setup
# entrypoint (git clone, DNS proxy, opencode config) is not needed here.
ENTRYPOINT []
CMD ["/bin/bash"]

LABEL org.opencontainers.image.title="issuepit-act-runner" \
      org.opencontainers.image.description="IssuePit act runner: helper-base + Docker Engine (DinD) + ffmpeg + jq + Go (Chrome and .NET already included via helper-base)" \
      issuepit.go.version="${GO_VERSION}"
