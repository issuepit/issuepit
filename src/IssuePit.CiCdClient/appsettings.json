{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CiCd": {
    "Runtime": "Docker",
    "ActBinaryPath": "act",
    "ActImage": "catthehacker/ubuntu:act-latest",
    "DefaultWorkspacePath": "",
    "DryRun": false,
    "Docker": {
      "Image": "ghcr.io/issuepit/issuepit-helper-act:latest"
    },
    "DindCache": {
      "Strategy": "Volume",
      "VolumePath": "/var/cache/issuepit/docker",
      "RegistryMirrorImage": "registry:2",
      "RegistryMirrorContainerName": "issuepit-registry-mirror",
      "RegistryMirrorPort": 5555,
      "RegistryMirrorVolumePath": "/var/cache/issuepit/registry",
      "RegistryMirrorHost": "172.17.0.1"
    }
  }
}
